# ==== Пересказ / перевод на русский ====
# Провайдер: claude | deepl | libretranslate | mock
# claude — РЕКОМЕНДУЕТСЯ. Не дословный перевод, а самостоятельный пересказ
# сути своими словами (см. src/aiRetell.js) — дешевле и безопаснее с точки
# зрения авторского права, чем переводить текст 1:1.
RUSSIAN_PROVIDER=claude

# Ключ Claude API. Получить: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Модель для пересказа. claude-haiku-4-5-20251001 — самая дешёвая из текущих
# моделей ($1/$5 за million tokens), для короткого пересказа заголовка и
# описания её точности достаточно с большим запасом.
# При желании более "литературного" пересказа можно поставить
# claude-sonnet-4-6 (дороже примерно в 3 раза, но качественнее стиль).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Альтернативы (если решите не использовать Claude) ----
# DeepL — дословный перевод, платно после 500k символов/мес
DEEPL_API_KEY=
# LibreTranslate — self-hosted, бесплатно, но качество FI->RU заметно хуже
LIBRETRANSLATE_URL=http://localhost:5000/translate
LIBRETRANSLATE_API_KEY=

# ==== Сервер ====
PORT=3000

# CORS выключен по умолчанию. Для браузерных клиентов укажите origin через запятую.
# Пример: https://finskienovosti.fi,https://www.finskienovosti.fi
CORS_ORIGIN=

# Токен для POST /api/news/refresh. Без токена ручное обновление отключено.
REFRESH_TOKEN=
# Минимальная пауза между успешными ручными обновлениями.
REFRESH_COOLDOWN_SECONDS=60

# HTTP Basic Auth для /admin. Без обеих переменных модерация закрыта.
ADMIN_USER=
ADMIN_PASSWORD=

# Ручная отправка статей в Telegram из /admin. Без обеих переменных отправка отключена.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Оставьте официальный URL; меняйте только для локального mock Telegram API.
TELEGRAM_API_BASE_URL=https://api.telegram.org

# Для Coolify за одним reverse proxy установите 1, чтобы получить IP клиента из X-Forwarded-For.
# Вне доверенного reverse proxy оставьте 0.
TRUST_PROXY=0

# Лимит публикации комментариев с одного IP-адреса.
COMMENT_RATE_LIMIT_WINDOW_SECONDS=600
COMMENT_RATE_LIMIT_MAX=3

# Сколько дней хранить анонимные дневные просмотры и реакции. Более старые записи
# удаляются при старте и ежедневно в 00:15 UTC.
ANALYTICS_RETENTION_DAYS=90

# Как часто обновлять новости из RSS (в минутах)
REFRESH_INTERVAL_MINUTES=15

# Путь к локальной SQLite-базе
DATABASE_PATH=data/finskienovosti.db

SITE_URL=http://localhost:3000
